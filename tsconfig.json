{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "~/*": ["app/*"]
    },
    "types": ["@remix-run/node", "@remix-run/dev"]
  },
  "include": ["app", "remix.env.d.ts", "*.config.*"],
  "exclude": ["node_modules", "build", "public/build"]
}
